{
  "name": "mdopen",
  "version": "0.1.0",
  "description": "Convert Markdown to GitHub-styled HTML (with syntax highlighting and Mermaid support) and open it in a browser",
  "keywords": ["markdown", "html", "mermaid", "shiki", "cli"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mdopen": "./bin/mdopen.js"
  },
  "files": [
    "dist",
    "bin",
    "themes"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bin": "bun build ./src/cli.ts --compile --outfile bin/mdopen",
    "build:themes": "bun run scripts/build-themes.ts",
    "test:visual": "bun run build:bin && playwright test tests/visual.spec.ts",
    "test:visual:update": "bun run build:bin && playwright test tests/visual.spec.ts --update-snapshots",
    "test:visual:report": "playwright show-report playwright-report",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commonmark": "^0.30.0",
    "github-markdown-css": "^5.8.0",
    "js-yaml": "^5.0.0",
    "markdown-it": "^14.0.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.0.0",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^12.0.0",
    "mermaid": "^11.16.0",
    "mermaid-parser-bundle": "^0.2.0",
    "prismjs": "^1.30.0",
    "remarkable": "^2.0.1",
    "toml": "^4.1.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^26.1.0",
    "csso": "^5.0.5",
    "typescript": "^5.5.0",
    "@playwright/test": "^1.48.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/happytomatoe/pi-open-message-in-browser",
    "directory": "packages/mdopen"
  },
  "license": "MIT"
}
